    "@angular/router": "20.3.15",
    "@modelcontextprotocol/sdk": "1.29.0",
    "rxjs": "7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.13",
    "@angular/cli": "20.3.13",
    "@angular/compiler-cli": "20.3.15",
    "@nx/angular": "22.1.3",
    "@nx/workspace": "22.1.3",
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
