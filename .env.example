# .env.example — Template di configurazione per selvans
#
# Copia questo file in .env e modifica i valori che ti servono:
#   cp .env.example .env        # macOS / Linux
#   copy .env.example .env      # Windows (cmd)
#
# NOTA: .env è ignorato da git. .env.example è tracciato e non deve
# contenere segreti reali — solo placeholder e valori di default.

# ─── selvans-python-demo ──────────────────────────────────────────────────

# URL del Core a cui la demo Python si connette.
# In Docker Compose il Core si raggiunge via nome servizio; in locale usa localhost.
Selvans_CORE_URL=http://localhost:8080

# ID applicazione con cui la demo si registra sul Core (default: demo-backend)
Selvans_APP_ID=demo-backend

# ─── selvans-core (override dei default) ──────────────────────────────────
# Queste variabili sono opzionali: il Core funziona senza di esse.
# Decommentale solo se devi cambiare i valori di default.

# Porta del Core (default: 8080)
# Selvans_PORT=8080

# Origini CORS ammesse (JSON array). In produzione restringi all'origine reale.
# Selvans_ALLOWED_ORIGINS=["http://localhost:4200"]

# ─── AI Provider ─────────────────────────────────────────────────────────────
# Seleziona il provider AI per la demo. Valori supportati: ollama | openai | anthropic
# Default: ollama (non richiede credenziali, usa un modello locale).
AI_PROVIDER=ollama

# Ollama — server locale (default per sviluppo; avvia Ollama prima di fare setup)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# OpenAI — decommenta e inserisci la tua chiave se usi AI_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_MODEL=gpt-4o-mini

# Anthropic — decommenta e inserisci la tua chiave se usi AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
